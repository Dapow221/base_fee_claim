# Base RPC. Public RPC works, but a private RPC is more reliable for 24/7 use.
BASE_RPC_URL=https://mainnet.base.org

# Dynamic mode watches the fee Release event across Base, then reads the receipt
# to discover the beneficiary/dev wallet and the claimed token contracts.
# Optional: restrict to one or more known fee distributor contracts, comma-separated.
# Leave empty to watch the Release event from every contract.
FEE_DISTRIBUTOR_ADDRESSES=

# Optional: ignore tiny claims. Values are raw wei-style token units.
MIN_RAW_CLAIM_AMOUNT=0

# Only alert when the released ETH/WETH amount is at least this value.
MIN_ETH_CLAIM_AMOUNT=0.1

# Optional market data. Uses DexScreener public API when enabled.
ENABLE_DEXSCREENER=true

# Telegram alerts. Create a bot with @BotFather and put your chat id here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord alerts. Put a channel webhook URL here.
DISCORD_WEBHOOK_URL=

# Polling/storage.
POLL_INTERVAL_MS=12000
CONFIRMATIONS=2
BLOCK_CHUNK_SIZE=150
STATE_FILE=.bot-state.json

# Optional testing mode. Set both values to scan a fixed historical block range and exit.
# Your sample transaction is in decimal block 46181876.
SCAN_ONCE_FROM_BLOCK=
SCAN_ONCE_TO_BLOCK=
